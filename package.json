{
  "name": "@frostr/bifrost",
  "version": "0.0.1",
  "description": "Core library for implementing the FROSTR signing protocol.",
  "author": "Christopher Scott",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/frostr-org/bifrost"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "files": [
    "README.md",
    "LICENSE",
    "dist",
    "src"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./api": {
      "import": "./dist/api/index.js",
      "types": "./dist/api/index.d.ts",
      "default": "./dist/api/index.js"
    },
    "./lib": {
      "import": "./dist/lib/index.js",
      "types": "./dist/lib/index.d.ts",
      "default": "./dist/lib/index.js"
    },
    "./util": {
      "import": "./dist/util/index.js",
      "types": "./dist/util/index.d.ts",
      "default": "./dist/util/index.js"
    }
  },
  "scripts": {
    "build": "./script/build.sh",
    "load": "tsx --tsconfig ./test/tsconfig.json",
    "release": "yarn test && yarn build",
    "scratch": "yarn load test/scratch.ts",
    "test": " yarn load test/tape.ts | tap-spec"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.1",
    "@types/tape": "^5.6.4",
    "rollup": "^4.24.0",
    "tap-spec": "^5.0.0",
    "tape": "^5.9.0",
    "tslib": "^2.8.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@cmdcode/buff": "^2.2.5"
  }
}
